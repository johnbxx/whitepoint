{
  "name": "whitepoint",
  "version": "0.2.0",
  "description": "Research-grade color math: every CSS color space, arbitrary illuminants, CATs, and CCT — digit-identical in JS, GLSL, and WGSL.",
  "type": "module",
  "main": "./src/index.js",
  "types": "./types.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./types.d.ts",
      "import": "./src/index.js"
    },
    "./codegen": {
      "types": "./codegen.d.ts",
      "import": "./src/codegen/index.js"
    },
    "./spectral": {
      "types": "./spectral.d.ts",
      "import": "./src/spectral/index.js"
    }
  },
  "bin": {
    "whitepoint-skill": "./bin/install-skill.js"
  },
  "files": [
    "src",
    "bin",
    "skills",
    "types.d.ts",
    "codegen.d.ts",
    "spectral.d.ts",
    "NORTHSTAR.md",
    "RECIPES.md"
  ],
  "scripts": {
    "test": "node --test",
    "precision": "node tools/precision-table.js",
    "bench": "node tools/bench.js",
    "alloc": "node --expose-gc tools/alloc-audit.js",
    "typecheck": "npx --yes --package typescript@5 tsc --noEmit --strict types.d.ts codegen.d.ts spectral.d.ts",
    "site": "npx --yes esbuild docs/_entry.js --bundle --format=esm --minify --outfile=docs/whitepoint.js"
  },
  "keywords": [
    "color",
    "colour",
    "color-space",
    "oklab",
    "oklch",
    "xyz",
    "illuminant",
    "chromatic-adaptation",
    "bradford",
    "cat16",
    "cct",
    "glsl",
    "wgsl",
    "shader",
    "display-p3",
    "rec2020",
    "gamut"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johnbxx/whitepoint.git"
  },
  "homepage": "https://johnbxx.github.io/whitepoint/",
  "bugs": {
    "url": "https://github.com/johnbxx/whitepoint/issues"
  },
  "devDependencies": {
    "@material/material-color-utilities": "^0.4.0",
    "@texel/color": "^1.1.11",
    "colorjs.io": "^0.5.2",
    "culori": "^4.0.1",
    "hsluv": "^1.0.1"
  }
}
